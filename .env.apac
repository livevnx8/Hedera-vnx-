# APAC Environment Configuration
VERA_REGION=apac
VERA_APAC_TOPIC_ID=0.0.10409353
VERA_PRIMARY_REGION=us-east
VERA_GEO_ROUTING_ENABLED=true
VERA_AUTO_FAILOVER=true

# Hedera Mainnet
HEDERA_NETWORK=mainnet
MIRROR_NODE_BASE_URL=https://mainnet-public.mirrornode.hedera.com

# Regional Settings
PORT=8080
NODE_ENV=production

# AI Configuration
MODEL_PROVIDER=google
DEFAULT_CHAT_MODEL=gemini-1.5-flash

# Regional Capacity
VERA_MAX_AGENTS=2000
VERA_MAX_HCS_PER_SECOND=200

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
