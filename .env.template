# VeraLattice Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080
NODE_ENV=production
DATABASE_PATH=./data.sqlite

# AI Configuration
AI_NAME=Vera.h
MODEL_PROVIDER=qvx-direct
DEFAULT_CHAT_MODEL=
NATIVE_CONTEXT_SIZE=32768
NATIVE_GPU_LAYERS=0

# Model Gateway URLs
QVX_INFER_URL=http://localhost:5101
QVX_NODE_URL=http://localhost:5100

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Google AI Studio Configuration
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here

# Hedera Configuration
HEDERA_NETWORK=mainnet
# IMPORTANT: Use secure key management for production
HEDERA_OPERATOR_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_OPERATOR_PRIVATE_KEY=USE_SECURE_KEY_MANAGEMENT
TREASURY_ACCOUNT_ID=
HCS_TOPIC_ID=
MIRROR_NODE_BASE_URL=https://mainnet-public.mirrornode.hedera.com
RECEIPT_SIGNING_SECRET_KEY_BASE64=

# Credits and Pricing
CREDIT_USD_PER_HBAR=0.05
PRICE_SOURCE=static

# Security Configuration (REQUIRED FOR PRODUCTION)
JWT_SECRET=your_jwt_secret_minimum_32_characters
SESSION_SECRET=your_session_secret_minimum_32_characters
ENCRYPTION_KEY=your_encryption_key_minimum_32_characters

# Rate Limiting
DEFAULT_RATE_LIMIT_PER_MINUTE=100
DEFAULT_RATE_LIMIT_PER_HOUR=1000
DEFAULT_RATE_LIMIT_PER_DAY=10000

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Image Generation
IMAGE_PROVIDER=replicate
REPLICATE_API_KEY=your_replicate_api_key_here

# Video Generation
VIDEO_PROVIDER=runway
RUNWAY_API_KEY=your_runway_api_key_here

# Cache Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL=300

# Feature Flags
ENABLE_ENHANCED_CAPABILITIES=true
ENABLE_COMPETITIVE_INTELLIGENCE=true
ENABLE_REASONING_ENHANCEMENT=true

# Security Notes:
# 1. Never commit actual secrets to version control
# 2. Use HSM or key management service for production private keys
# 3. Rotate keys regularly
# 4. Use different secrets for development and production
# 5. Monitor for unauthorized access attempts
