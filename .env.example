PORT=8080
DATABASE_PATH=./data.sqlite
AI_NAME=VERA

# Hedera
HEDERA_NETWORK=mainnet
HEDERA_OPERATOR_ACCOUNT_ID=
HEDERA_OPERATOR_PRIVATE_KEY=
TREASURY_ACCOUNT_ID=
HCS_TOPIC_ID=
# Vera payment orchestration topics (optional: populate after creating topics)
VERA_REGISTRY_TOPIC_ID=
VERA_TASK_TOPIC_ID=
VERA_RESULT_TOPIC_ID=
VERA_AUDIT_TOPIC_ID=
MIRROR_NODE_BASE_URL=https://mainnet-public.mirrornode.hedera.com
RECEIPT_SIGNING_SECRET_KEY_BASE64=

# Credits / Pricing
CREDIT_USD_PER_HBAR=0.05
PRICE_SOURCE=static
SAUCERSWAP_API_KEY=

# Model Gateway: ollama | openai | google | custom | qvx-direct | native
# - google: Use Google AI Studio (Gemini) — best tool-calling reliability
#   Set GOOGLE_AI_STUDIO_API_KEY and DEFAULT_CHAT_MODEL=gemini-2.0-flash
# - openai: Use OpenAI API or any OpenAI-compatible endpoint
# - ollama: Local Ollama instance (set OLLAMA_URL)
# - qvx-direct: Custom QVX inference server (local fine-tuned model)
# - native: Run a GGUF model file directly (no Ollama needed)
MODEL_PROVIDER=ollama

# --- Native inference (MODEL_PROVIDER=native) ---
# Absolute or relative path to your GGUF model file
MODEL_PATH=./models/vera-model.gguf
# KV cache context window size (tokens). 4096 is safe; larger needs more VRAM/RAM
NATIVE_CONTEXT_SIZE=4096
# Number of layers to offload to GPU. 0 = CPU only, -1 = all layers on GPU
NATIVE_GPU_LAYERS=0

# --- Sovereign LLM Routing (Hybrid Local + API Fallback) ---
# Local model for sovereign inference (13B fits in 8GB VRAM)
SOVEREIGN_LOCAL_MODEL=llama3.1:13b
# Fallback provider for high-complexity requests: google | openai | none
SOVEREIGN_FALLBACK_PROVIDER=none
# Model to use for API fallback (Gemini recommended for cost/quality)
SOVEREIGN_FALLBACK_MODEL=gemini-1.5-flash-8b
# Complexity threshold (0-1) for triggering API fallback. 0.85 = 85% of complex queries go to API
SOVEREIGN_COMPLEXITY_THRESHOLD=0.85
# Whether to use API fallback for agent tool sequences (high complexity)
SOVEREIGN_FALLBACK_FOR_AGENT_TOOLS=false

# --- NVIDIA / Sovereign Acceleration ---
# Prefer these local lanes for normal Vera operation and private repo learning.
USE_NIM=false
NIM_URL=http://localhost:8000
NIM_MODEL=meta/llama3-8b-instruct
NIM_API_KEY=
NIM_MAX_TOKENS=2048
NIM_TEMPERATURE=0.7
USE_VLLM=false
VLLM_URL=http://localhost:8000
VLLM_MODEL=llama3.1:8b
NEMOTRON_URL=http://localhost:8000
NEMOTRON_MODEL=nemotron-nano
NEMOTRON_PROVIDER=nim
NEMOTRON_API_KEY=

# --- Meridian BitNet Research Lane ---
# pytorch = local research checkpoint, bitnetcpp = official bitnet.cpp + GGUF.
ENABLE_MERIDIAN_BITNET=false
MERIDIAN_URL=http://localhost:8123
MERIDIAN_BACKEND=pytorch
MERIDIAN_BITNETCPP_MODEL=models/BitNet-b1.58-2B-4T/ggml-model-i2_s.gguf
MERIDIAN_BITNETCPP_DIR=vendor/BitNet
MERIDIAN_BITNETCPP_THREADS=4
MERIDIAN_BITNETCPP_CTX_SIZE=2048
MERIDIAN_BITNETCPP_TIMEOUT_MS=120000

# --- Vera Learning Lane ---
# Optional pro/reasoning lane for agent upgrade packages, codebase learning,
# and ecosystem lessons. Use an OpenAI-compatible endpoint for DeepSeek-style
# models after confirming the provider's live model id.
VERA_LEARNING_ENABLED=false
VERA_LEARNING_PROVIDER=none
VERA_LEARNING_BASE_URL=
VERA_LEARNING_API_KEY=
VERA_LEARNING_MODEL=
VERA_LEARNING_MIN_QUALITY_SCORE=0.82
VERA_LEARNING_RECEIPTS_REQUIRED=true
VERA_LEARNING_ALLOW_BLOCK_STREAM=true

# --- Private Git Lattice Tree ---
# Private repo/codebase map for Vera's own development learning. Keep private by
# default; index structure, symbols, docs, tests, and commit lessons, not secrets.
VERA_GIT_LATTICE_ENABLED=false
VERA_GIT_LATTICE_MODE=private
VERA_GIT_LATTICE_ROOT=./
VERA_GIT_LATTICE_INCLUDE_PRIVATE=false
VERA_GIT_LATTICE_MAX_FILE_KB=256
VERA_GIT_LATTICE_SECRET_SCAN_REQUIRED=true

# Vera marketplace one-time agent creation fee
VERA_SKIP_ORCHESTRATOR_START=false
VERA_AGENT_CREATION_FEE_TARGET_USD=7.5
VERA_AGENT_CREATION_FEE_HBAR=10
VERA_AGENT_CREATION_FEE_TOKEN_AMOUNT=100
VERA_AGENT_CREATION_FEE_TOKEN_ID=0.0.9356476
VERA_AGENT_CREATION_FEE_TOKEN_SYMBOL=hbar.h
VERA_AGENT_CREATION_FEE_TOKEN_USD_FALLBACK=0.0005
VERA_AGENT_CREATION_FEE_PRICE_TOLERANCE=0.03
VERA_AGENT_CREATION_FEE_TREASURY_ACCOUNT=0.0.10294360

OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GOOGLE_AI_STUDIO_API_KEY=
DEFAULT_CHAT_MODEL=llama3.1:8b
DEFAULT_CODE_MODEL=qwen2.5-coder:7b

# Image Generation: disabled | automatic1111 | replicate | stability
IMAGE_PROVIDER=disabled
IMAGE_PROVIDER_URL=http://localhost:7860
REPLICATE_API_KEY=
STABILITY_API_KEY=

# Video Generation: disabled | replicate
VIDEO_PROVIDER=disabled
REPLICATE_VIDEO_MODEL=minimax/video-01

# QVX Node
QVX_NODE_URL=
QVX_NODE_API_KEY=

# x402 Micropayment integration
X402_BASE_URL=
X402_API_KEY=
X402_FACILITATOR_ACCOUNT=

# FedEx Supply Chain Topics (created via scripts/create-fedex-topics.mjs)
# These will be populated after running the topic creation script
FEDEX_ROUTE_TOPIC_ID=
FEDEX_PKG_TOPIC_ID=
FEDEX_CHAIN_TOPIC_ID=
FEDEX_AIR_TOPIC_ID=
FEDEX_GROUND_TOPIC_ID=
FEDEX_INTL_TOPIC_ID=
FEDEX_OPT_TOPIC_ID=
FEDEX_AUDIT_TOPIC_ID=

# FedEx API Integration (for future Phase 3 integration)
# FEDEX_API_KEY=
# FEDEX_API_SECRET=
# FEDEX_ACCOUNT_NUMBER=
# FEDEX_ENVIRONMENT=sandbox

# Carbon & Energy Tracking (Phase 12) - Real Data APIs
# Get API keys from:
# - ElectricityMap: https://api-portal.electricitymaps.com/
# - WattTime: https://watttime.org/docs-dev/
# - Ember: https://ember-climate.org/api/
# - Hedera Guardian: https://docs.hedera.com/guardian
ELECTRICITY_MAP_API_KEY=
WATTTIME_TOKEN=
EMBER_API_KEY=
HEDERA_GUARDIAN_KEY=
HEDERA_CARBON_TOPIC_ID=

# Hedera Guardian API URL (testnet or mainnet)
HEDERA_GUARDIAN_URL=https://testnet.guardian.hedera.com

# ─── New Integrations ───────────────────────────────────────────────────────

# Qdrant Vector Store (self-hosted alternative to Pinecone)
# docker run -p 6333:6333 qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=vera-lattice
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=Cosine

# ClickHouse Metrics (time-series analytics)
# docker run -p 8123:8123 clickhouse/clickhouse-server
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=vera_metrics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Oracle / Price Feeds
CHAINLINK_HBAR_USD_FEED=
PYTH_HBAR_PRICE_ID=
HEDERA_EVM_RPC=https://mainnet.hashio.io/api

# Confidential Compute (Intel TDX / AMD SEV)
VERA_ALLOWED_MRTDS=
VERA_MIN_TCB_VERSION=
VERA_ATTESTATION_TOPIC_ID=
