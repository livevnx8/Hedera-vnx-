# Vera Sandbox Environment Configuration
# Copy this file to .env.sandbox.local and customize for your setup

# =============================================================================
# Hedera Network Configuration
# =============================================================================

# Network: testnet or mainnet
HEDERA_NETWORK=testnet

# Testnet Account (auto-populated by scripts/setup-testnet.mjs)
HEDERA_TESTNET_ACCOUNT_ID=0.0.xxxx
HEDERA_TESTNET_PRIVATE_KEY=your-private-key-here

# Mirror Node
MIRROR_NODE_BASE_URL=https://testnet.mirrornode.hedera.com

# =============================================================================
# HCS Topic IDs (auto-created by setup script)
# =============================================================================

VERA_CORE_TOPIC_ID=0.0.xxxx
VERA_DEFI_TOPIC_ID=0.0.xxxx
VERA_CARBON_TOPIC_ID=0.0.xxxx
VERA_ENERGY_TOPIC_ID=0.0.xxxx

# =============================================================================
# Sandbox Mode
# =============================================================================

# Enable mock services (no real Hedera network needed)
MOCK_MODE=false

# Auto-create topics on startup
AUTO_CREATE_TOPICS=true

# Sandbox identifier
SANDBOX_MODE=true

# =============================================================================
# Service URLs (used in Docker Compose)
# =============================================================================

# QVX ML Service (mock)
QVX_MOCK_URL=http://qvx-mock:5101

# Redis
REDIS_URL=redis://redis-dev:6379

# PostgreSQL
POSTGRES_URL=postgresql://vera:vera@postgres-dev:5432/vera_sandbox

# =============================================================================
# Feature Flags
# =============================================================================

# Enable agent auto-start
AGENT_AUTO_START=false

# Enable debug logging
DEBUG=false
LOG_LEVEL=info

# Enable metrics collection
METRICS_ENABLED=true

# =============================================================================
# Development Settings
# =============================================================================

NODE_ENV=development
PORT=8080

# Node.js debugging (port 9229)
NODE_OPTIONS=--max-old-space-size=4096 --inspect=0.0.0.0:9229

# Thread pool size
UV_THREADPOOL_SIZE=64

# Hot reload
CHOKIDAR_USEPOLLING=true

# =============================================================================
# API Keys (for external services - optional)
# =============================================================================

# Hedera testnet portal API key (if using faucet)
HEDERA_PORTAL_API_KEY=

# Weather API (for energy forecasting)
WEATHER_API_KEY=

# Carbon registry API keys
VERRA_API_KEY=
GOLD_STANDARD_API_KEY=
ACR_API_KEY=

# =============================================================================
# Security (for production-like testing)
# =============================================================================

# JWT secret for authentication
JWT_SECRET=vera-sandbox-secret-change-in-production

# API rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
