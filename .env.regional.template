# Regional Deployment Environment Variables
# Copy to .env and fill in actual topic IDs

# Regional HCS Topics
VERA_US_EAST_TOPIC_ID=0.0.10409351
VERA_EU_WEST_TOPIC_ID=0.0.10409352
VERA_APAC_TOPIC_ID=0.0.10409353

# Current Region (set per deployment)
VERA_REGION=us-east

# Regional Endpoints
VERA_US_EAST_ENDPOINT=https://us-east.veralattice.com
VERA_EU_WEST_ENDPOINT=https://eu-west.veralattice.com
VERA_APAC_ENDPOINT=https://apac.veralattice.com

# Geo-DNS Configuration
VERA_GEO_ROUTING_ENABLED=true
VERA_HEALTH_CHECK_INTERVAL_MS=10000
VERA_SYNC_INTERVAL_MS=30000
VERA_AUTO_FAILOVER=true

# Regional Capacity Limits
VERA_US_EAST_MAX_AGENTS=5000
VERA_EU_WEST_MAX_AGENTS=3000
VERA_APAC_MAX_AGENTS=2000
