# VeraBridge Deployment Configuration
# Copy this file to .env and fill in your values

# ============================================
# VERA BRIDGE DEPLOYMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git!

# ============================================
# ETHEREUM CONFIGURATION (REQUIRED FOR DEPLOY)
# ============================================
# Your Ethereum private key - 64 hex characters (32 bytes)
# Format: 0x1234567890abcdef... (66 chars total with 0x prefix)
# OR: 1234567890abcdef... (64 chars without prefix)
# 
# ⚠️  WARNING: This key will be used to deploy contracts and spend gas!
# ⚠️  Use a dedicated deployer wallet, not your main wallet!
# 
# Example valid keys:
# ETHEREUM_PRIVATE_KEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
# ETHEREUM_PRIVATE_KEY=1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef
#
# Get a key from MetaMask: Account menu → Account details → Export private key
ETHEREUM_PRIVATE_KEY=0x...

# RPC URLs (optional - defaults to public nodes)
# Get free RPC from: https://www.alchemy.com or https://www.infura.io
ETHEREUM_RPC_URL=https://eth.llamarpc.com
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# RPC URLs (optional - defaults to public nodes)
ETHEREUM_RPC_URL=https://eth.llamarpc.com
GOERLI_RPC_URL=https://goerli.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Arbitrum
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Optimism
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Base
BASE_RPC_URL=https://mainnet.base.org

# Polygon
POLYGON_RPC_URL=https://polygon.llamarpc.com

# BSC
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Avalanche
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Block explorer API keys for verification
ETHERSCAN_API_KEY=...
ARBISCAN_API_KEY=...
OPTIMISTIC_ETHERSCAN_API_KEY=...
POLYGONSCAN_API_KEY=...
BSCSCAN_API_KEY=...
SNOWTRACE_API_KEY=...
BASESCAN_API_KEY=...

# ============================================
# HEDERA CONFIGURATION
# ============================================
# Your Hedera operator account (0.0.xxxxx)
HEDERA_OPERATOR_ACCOUNT_ID=0.0...

# Your Hedera private key (ED25519 or ECDSA)
HEDERA_OPERATOR_PRIVATE_KEY=...

# Hedera network: 'mainnet' or 'testnet'
HEDERA_NETWORK=testnet

# Bridge contract ID (after deployment)
HEDERA_BRIDGE_CONTRACT_ID=0.0...

# HCS topic for bridge attestations
HEDERA_BRIDGE_TOPIC_ID=0.0...

# ============================================
# VALIDATOR CONFIGURATION
# ============================================
# Validator ID (e.g., validator-1)
VALIDATOR_ID=validator-1

# Validator Hedera account
VALIDATOR_HEDERA_ACCOUNT_ID=0.0...
VALIDATOR_HEDERA_PRIVATE_KEY=...

# Validator Ethereum key (for signing)
VALIDATOR_ETHEREUM_PRIVATE_KEY=0x...

# ============================================
# BRIDGE CONFIGURATION
# ============================================
# Fee structure (in basis points)
BRIDGE_STANDARD_FEE_BPS=10      # 0.10%
BRIDGE_PARTNER_FEE_BPS=8        # 0.08%
BRIDGE_FOUNDING_FEE_BPS=5       # 0.05%

# Required validator signatures
REQUIRED_SIGNATURES=3

# HTLC expiry time in seconds (default: 24 hours)
HTLC_EXPIRY_SECONDS=86400

# ============================================
# API & SERVICES
# ============================================
# API base URL
API_BASE_URL=https://api.veralattice.com/v1/bridge

# Partner API key
PARTNER_API_KEY=...
PARTNER_ID=...

# Webhook URL for notifications
WEBHOOK_URL=https://your-site.com/webhook

# ============================================
# MONITORING
# ============================================
# Discord webhook for alerts
DISCORD_WEBHOOK_URL=...

# Slack webhook for alerts  
SLACK_WEBHOOK_URL=...

# Prometheus metrics port
METRICS_PORT=9090

# ============================================
# SECURITY
# ============================================
# Enable mainnet deployments (set to 'true' to confirm)
CONFIRM_MAINNET_DEPLOYMENT=false

# Multi-sig threshold for admin actions
ADMIN_MULTISIG_THRESHOLD=2
