#!/bin/bash
# Vera Sandbox - Docker Compose Helper
# Wraps docker-compose commands with sandbox-specific settings

COMPOSE_FILE="docker-compose.sandbox.yml"
ENV_FILE=".env.sandbox.local"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check if we have an environment file
if [ -f "$ENV_FILE" ]; then
    export $(cat "$ENV_FILE" | grep -v '^#' | xargs)
fi

case "${1:-}" in
    up)
        echo -e "${BLUE}Starting Vera Sandbox...${NC}"
        if [ -f "$ENV_FILE" ]; then
            docker-compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" up -d "${@:2}"
        else
            docker-compose -f "$COMPOSE_FILE" up -d "${@:2}"
        fi
        ;;
    down)
        echo -e "${BLUE}Stopping Vera Sandbox...${NC}"
        docker-compose -f "$COMPOSE_FILE" down "${@:2}"
        ;;
    logs)
        echo -e "${BLUE}Showing logs...${NC}"
        docker-compose -f "$COMPOSE_FILE" logs -f "${@:2}"
        ;;
    build)
        echo -e "${BLUE}Building images...${NC}"
        docker-compose -f "$COMPOSE_FILE" build "${@:2}"
        ;;
    ps)
        docker-compose -f "$COMPOSE_FILE" ps
        ;;
    exec)
        docker-compose -f "$COMPOSE_FILE" exec "${@:2}"
        ;;
    *)
        echo "Vera Sandbox Docker Helper"
        echo ""
        echo "Usage: sandbox-compose <command> [options]"
        echo ""
        echo "Commands:"
        echo "  up      Start sandbox services"
        echo "  down    Stop sandbox services"
        echo "  logs    View logs (-f to follow)"
        echo "  build   Build/rebuild images"
        echo "  ps      List running services"
        echo "  exec    Execute command in container"
        echo ""
        echo "Examples:"
        echo "  sandbox-compose up -d           # Start all services"
        echo "  sandbox-compose up qvx-mock     # Start only QVX mock"
        echo "  sandbox-compose logs vera-sandbox"
        echo "  sandbox-compose exec vera-sandbox sh"
        ;;
esac
