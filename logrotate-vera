/mnt/vera-mirror-shards/vera-lattice/logs/*.log {
    daily
    rotate 30
    compress
    delaycompress
    missingok
    notifempty
    create 0644 vera-live-0-1 vera-live-0-1
    dateext
    dateformat -%Y%m%d-%s
    
    # Rotate when larger than 100MB
    size 100M
    
    # Keep only 30 days
    maxage 30
    
    # Post-rotate script
    postrotate
        # Signal Vera to reopen logs if needed
        /bin/kill -HUP $(cat /tmp/vera.pid 2>/dev/null) 2>/dev/null || true
    endscript
}

# Also rotate any logs in the main project directory
/home/vera-live-0-1/hedera-llm-api/*.log {
    daily
    rotate 7
    compress
    delaycompress
    missingok
    notifempty
    create 0644 vera-live-0-1 vera-live-0-1
    size 50M
    maxage 7
}
